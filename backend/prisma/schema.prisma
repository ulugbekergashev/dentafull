generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Doctor {
  id             String        @id @default(uuid())
  firstName      String
  lastName       String
  specialty      String
  phone          String
  email          String?
  status         String
  username       String?       @unique
  password       String?
  clinicId       String
  telegramChatId String?
  percentage     Float         @default(0)
  color          String?
  secondaryPhone String?
  appointments   Appointment[]
  clinic         Clinic        @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, telegramChatId])
}

model Receptionist {
  id        String @id @default(uuid())
  firstName String
  lastName  String
  phone     String
  username  String @unique
  password  String
  status    String
  clinicId  String
  clinic    Clinic @relation(fields: [clinicId], references: [id])
}

model Patient {
  id             String             @id @default(uuid())
  firstName      String
  lastName       String
  phone          String
  dob            String
  lastVisit      String
  status         String
  gender         String
  medicalHistory String
  clinicId       String
  telegramChatId String?
  address        String?
  createdAt      DateTime           @default(now())
  secondaryPhone String?
  avatarUrl      String?
  portraitUrl    String?
  balance        Float              @default(0)
  appointments   Appointment[]
  inventoryLogs  InventoryLog[]
  clinic         Clinic             @relation(fields: [clinicId], references: [id])
  diagnoses      PatientDiagnosis[]
  photos         PatientPhoto[]
  telegramLogs   TelegramLog[]
  teeth          ToothData[]
  transactions   Transaction[]
  visits         Visit[]

  @@unique([clinicId, telegramChatId])
  @@index([phone])
}

model ToothData {
  id         Int      @id @default(autoincrement())
  patientId  String
  number     Int
  conditions String
  notes      String?
  updatedAt  DateTime @updatedAt
  patient    Patient  @relation(fields: [patientId], references: [id])

  @@unique([patientId, number])
}

model PatientPhoto {
  id          String   @id @default(uuid())
  patientId   String
  url         String
  description String?
  category    String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  patient     Patient  @relation(fields: [patientId], references: [id])
}

model Appointment {
  id           String  @id @default(uuid())
  patientId    String
  patientName  String
  doctorId     String
  doctorName   String
  type         String
  date         String
  time         String
  duration     Int
  status       String
  notes        String?
  clinicId     String
  reminderSent Boolean @default(false)
  clinic       Clinic  @relation(fields: [clinicId], references: [id])
  doctor       Doctor  @relation(fields: [doctorId], references: [id])
  patient      Patient @relation(fields: [patientId], references: [id])
  review       Review?
  visits       Visit[]

  @@unique([patientId, date], name: "unique_patient_date")
  @@index([date])
  @@index([patientId])
}

model Visit {
  id            String               @id @default(uuid())
  patientId     String
  appointmentId String?
  date          String
  checkInTime   DateTime             @default(now())
  checkOutTime  DateTime?
  status        String               @default("Waiting")
  complaints    String?
  vitalSigns    String?
  notes         String?
  clinicId      String
  diagnoses     PatientDiagnosis[]
  transactions  Transaction[]
  procedures    TreatmentProcedure[]
  appointment   Appointment?         @relation(fields: [appointmentId], references: [id])
  clinic        Clinic               @relation(fields: [clinicId], references: [id])
  patient       Patient              @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([date])
}

model TreatmentProcedure {
  id            String    @id @default(uuid())
  visitId       String
  procedureName String
  toothNumber   Int?
  toothSurface  String?
  status        String    @default("Planned")
  basePrice     Float
  discount      Float     @default(0)
  finalPrice    Float
  materialsUsed String?
  notes         String?
  duration      Int?
  doctorId      String
  doctorName    String
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  visit         Visit     @relation(fields: [visitId], references: [id])

  @@index([visitId])
  @@index([toothNumber])
}

model Transaction {
  id              String   @id @default(uuid())
  patientName     String
  date            String
  amount          Float
  type            String
  service         String
  status          String
  clinicId        String
  doctorId        String?
  doctorName      String?
  patientId       String?
  visitId         String?
  discountAmount  Float?   @default(0)
  discountPercent Float?   @default(0)
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  patient         Patient? @relation(fields: [patientId], references: [id])
  visit           Visit?   @relation(fields: [visitId], references: [id])
}

model Service {
  id         Int              @id @default(autoincrement())
  name       String
  price      Float
  duration   Int
  clinicId   String
  cost       Float            @default(0)
  categoryId String?
  category   ServiceCategory? @relation(fields: [categoryId], references: [id])
  clinic     Clinic           @relation(fields: [clinicId], references: [id])
}

model SubscriptionPlan {
  id         String   @id
  name       String
  price      Float
  maxDoctors Int
  features   String
  clinics    Clinic[]
}

model Clinic {
  id                    String             @id @default(uuid())
  name                  String
  adminName             String
  username              String             @unique
  password              String?
  phone                 String
  status                String
  planId                String
  subscriptionStartDate String
  expiryDate            String
  monthlyRevenue        Float
  telegramChatId        String?
  botToken              String?
  subscriptionType      String             @default("Paid")
  smsBalance            Float              @default(0)
  smsLimit              Int                @default(0)
  smsUsedThisMonth      Int                @default(0)
  ownerPhone            String?
  facebookPageId        String?
  facebookPageAccessToken String?
  facebookUserAccessToken String?
  facebookPageName      String?
  customPrice           Float?
  appointments          Appointment[]
  plan                  SubscriptionPlan   @relation(fields: [planId], references: [id])
  doctors               Doctor[]
  inventoryItems        InventoryItem[]
  leads                 Lead[]
  patients              Patient[]
  diagnoses             PatientDiagnosis[]
  receptionists         Receptionist[]
  services              Service[]
  serviceCategories     ServiceCategory[]
  telegramLogs          TelegramLog[]
  transactions          Transaction[]
  visits                Visit[]

  @@index([botToken])
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  phone     String
  service   String?
  source    String?
  notes     String?
  status    String   @default("New")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
  @@index([status])
}

model ICD10Code {
  code        String             @id
  name        String
  description String?
  category    String?
  diagnoses   PatientDiagnosis[]
}

model PatientDiagnosis {
  id        String    @id @default(uuid())
  patientId String
  code      String
  date      String
  notes     String?
  status    String
  clinicId  String
  visitId   String?
  clinic    Clinic    @relation(fields: [clinicId], references: [id])
  icd10     ICD10Code @relation(fields: [code], references: [code])
  patient   Patient   @relation(fields: [patientId], references: [id])
  visit     Visit?    @relation(fields: [visitId], references: [id])
}

model InventoryItem {
  id          String         @id @default(uuid())
  name        String
  unit        String
  quantity    Float          @default(0)
  minQuantity Float          @default(0)
  clinicId    String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  clinic      Clinic         @relation(fields: [clinicId], references: [id])
  logs        InventoryLog[]
}

model InventoryLog {
  id        String        @id @default(uuid())
  itemId    String
  change    Float
  type      String
  note      String?
  date      DateTime      @default(now())
  userName  String
  patientId String?
  item      InventoryItem @relation(fields: [itemId], references: [id])
  patient   Patient?      @relation(fields: [patientId], references: [id])

  @@index([itemId])
  @@index([patientId])
}

model ServiceCategory {
  id       String    @id @default(uuid())
  name     String
  clinicId String
  services Service[]
  clinic   Clinic    @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, name])
}

model Review {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
}

model TelegramLog {
  id        String   @id @default(uuid())
  clinicId  String
  patientId String?
  type      String
  status    String
  message   String?
  error     String?
  sentAt    DateTime @default(now())
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  patient   Patient? @relation(fields: [patientId], references: [id])

  @@index([clinicId])
  @@index([patientId])
}
